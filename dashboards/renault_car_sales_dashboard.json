{
  "datasets": [
    {
      "name": "ds_overview_kpis",
      "displayName": "Vue d'ensemble - KPIs",
      "queryLines": [
        "SELECT ",
        "  SUM(nb_listings) AS total_annonces, ",
        "  SUM(total_revenue) AS chiffre_affaires, ",
        "  ROUND(SUM(total_revenue) / NULLIF(SUM(nb_listings), 0), 0) AS prix_moyen, ",
        "  ROUND(SUM(nb_electrique) * 100.0 / NULLIF(SUM(nb_listings), 0), 1) AS part_ev_pct, ",
        "  SUM(nb_neuf) AS total_neuf, ",
        "  SUM(nb_occasion) AS total_occasion ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.concession_daily_kpis"
      ]
    },
    {
      "name": "ds_revenue_trend",
      "displayName": "Tendance CA mensuel",
      "queryLines": [
        "SELECT ",
        "  DATE_TRUNC('MONTH', sale_date) AS mois, ",
        "  SUM(total_revenue) AS chiffre_affaires, ",
        "  SUM(nb_listings) AS nb_annonces ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.concession_daily_kpis ",
        "GROUP BY DATE_TRUNC('MONTH', sale_date) ",
        "ORDER BY mois"
      ]
    },
    {
      "name": "ds_listings_region",
      "displayName": "Annonces par région",
      "queryLines": [
        "SELECT ",
        "  region, ",
        "  SUM(nb_listings) AS nb_annonces, ",
        "  SUM(total_revenue) AS chiffre_affaires ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.concession_daily_kpis ",
        "GROUP BY region ",
        "ORDER BY nb_annonces DESC"
      ]
    },
    {
      "name": "ds_energy_mix",
      "displayName": "Mix énergie",
      "queryLines": [
        "SELECT ",
        "  'Électrique' AS energie, SUM(nb_electrique) AS nb FROM serverless_stable_le1wzb_catalog.car_sales.concession_daily_kpis ",
        "UNION ALL ",
        "SELECT 'Hybride', SUM(nb_hybride) FROM serverless_stable_le1wzb_catalog.car_sales.concession_daily_kpis ",
        "UNION ALL ",
        "SELECT 'Thermique', SUM(nb_thermique) FROM serverless_stable_le1wzb_catalog.car_sales.concession_daily_kpis"
      ]
    },
    {
      "name": "ds_group_scorecard",
      "displayName": "Scorecard Groupes",
      "queryLines": [
        "SELECT ",
        "  group_name, ",
        "  SUM(nb_listings) AS nb_annonces, ",
        "  SUM(total_revenue) AS chiffre_affaires, ",
        "  ROUND(SUM(total_revenue) / NULLIF(SUM(nb_listings), 0), 0) AS prix_moyen, ",
        "  ROUND(SUM(nb_ev) * 100.0 / NULLIF(SUM(nb_listings), 0), 1) AS part_ev_pct, ",
        "  ROUND(SUM(nb_listings * neuf_share_pct) / NULLIF(SUM(nb_listings), 0), 1) AS part_neuf_pct, ",
        "  MAX(nb_concessions) AS nb_concessions ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.group_scorecard ",
        "GROUP BY group_name ",
        "ORDER BY chiffre_affaires DESC"
      ]
    },
    {
      "name": "ds_concession_daily",
      "displayName": "Tendance concessions",
      "queryLines": [
        "SELECT ",
        "  DATE_TRUNC('WEEK', sale_date) AS semaine, ",
        "  group_name, ",
        "  SUM(total_revenue) AS chiffre_affaires ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.concession_daily_kpis ",
        "GROUP BY DATE_TRUNC('WEEK', sale_date), group_name ",
        "ORDER BY semaine"
      ]
    },
    {
      "name": "ds_top_concessions",
      "displayName": "Top 10 Concessions",
      "queryLines": [
        "SELECT ",
        "  concession_name, ",
        "  region, ",
        "  group_name, ",
        "  SUM(total_revenue) AS chiffre_affaires ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.concession_daily_kpis ",
        "GROUP BY concession_name, region, group_name ",
        "ORDER BY chiffre_affaires DESC ",
        "LIMIT 10"
      ]
    },
    {
      "name": "ds_model_perf",
      "displayName": "Performance Modèles",
      "queryLines": [
        "SELECT ",
        "  brand AS marque, ",
        "  model AS modele, ",
        "  version, ",
        "  segment, ",
        "  SUM(nb_listings) AS nb_annonces, ",
        "  SUM(total_revenue) AS chiffre_affaires, ",
        "  ROUND(SUM(total_revenue) / NULLIF(SUM(nb_listings), 0), 0) AS prix_moyen, ",
        "  SUM(nb_electrique) AS nb_ev, ",
        "  SUM(nb_hybride) AS nb_hybride ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.model_performance ",
        "GROUP BY brand, model, version, segment ",
        "ORDER BY chiffre_affaires DESC"
      ]
    },
    {
      "name": "ds_brand_mix",
      "displayName": "Mix Marques",
      "queryLines": [
        "SELECT ",
        "  brand AS marque, ",
        "  SUM(nb_listings) AS nb_annonces ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.model_performance ",
        "GROUP BY brand ",
        "ORDER BY nb_annonces DESC"
      ]
    },
    {
      "name": "ds_segment_revenue",
      "displayName": "CA par Segment",
      "queryLines": [
        "SELECT ",
        "  segment, ",
        "  SUM(total_revenue) AS chiffre_affaires ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.model_performance ",
        "GROUP BY segment ",
        "ORDER BY chiffre_affaires DESC"
      ]
    },
    {
      "name": "ds_ev_trend",
      "displayName": "Tendance EV vs Thermique",
      "queryLines": [
        "SELECT mois, energie, nb FROM ( ",
        "  SELECT CONCAT(year, '-', LPAD(month, 2, '0')) AS mois, ",
        "    'Électrique' AS energie, SUM(nb_electrique) AS nb ",
        "  FROM serverless_stable_le1wzb_catalog.car_sales.model_performance GROUP BY year, month ",
        "  UNION ALL ",
        "  SELECT CONCAT(year, '-', LPAD(month, 2, '0')), ",
        "    'Hybride', SUM(nb_hybride) ",
        "  FROM serverless_stable_le1wzb_catalog.car_sales.model_performance GROUP BY year, month ",
        "  UNION ALL ",
        "  SELECT CONCAT(year, '-', LPAD(month, 2, '0')), ",
        "    'Thermique', SUM(nb_listings) - SUM(nb_electrique) - SUM(nb_hybride) ",
        "  FROM serverless_stable_le1wzb_catalog.car_sales.model_performance GROUP BY year, month ",
        ") ORDER BY mois, energie"
      ]
    },
    {
      "name": "ds_listings_detail",
      "displayName": "Détail Annonces",
      "queryLines": [
        "SELECT ",
        "  listing_id, ",
        "  sale_date AS date_vente, ",
        "  concession_name AS concession, ",
        "  region, ",
        "  group_name AS groupe, ",
        "  brand AS marque, ",
        "  model AS modele, ",
        "  version, ",
        "  segment, ",
        "  year_immat AS annee_immat, ",
        "  age, ",
        "  km, ",
        "  energy AS energie, ",
        "  etat, ",
        "  price AS prix, ",
        "  nb_photos ",
        "FROM serverless_stable_le1wzb_catalog.car_sales.listings_detail ",
        "ORDER BY sale_date DESC ",
        "LIMIT 5000"
      ]
    }
  ],
